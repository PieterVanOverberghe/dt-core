<?xml version="1.0" encoding="utf-8"?>
<launch>
    <arg name="veh" default="$(env VEHICLE_NAME)"/>
    <arg name="camera_topic" default="camera_node"/>
    <arg name="param_file_name" default="default"/>
    <arg name="traffic_mode" default="right"/>

    <!-- Keep defaults minimal to validate camera -> segments -> ground projection first. -->
    <arg name="enable_decoder" default="false"/>
    <arg name="enable_anti_instagram" default="false"/>
    <arg name="enable_lane_filter" default="false"/>
    <arg name="enable_lane_controller" default="false"/>
    <arg name="enable_kinematics" default="false"/>

    <group if="$(arg enable_decoder)">
        <env name="FSM_NODE_CONTROL" value="0"/>
        <param name="/$(arg veh)/decoder_node/switch" value="true"/>
        <remap from="decoder_node/image_in" to="$(arg camera_topic)/image/compressed"/>
        <remap from="decoder_node/image_out" to="$(arg camera_topic)/image/raw"/>
        <include file="$(find image_processing)/launch/image_decoding.launch">
            <arg name="veh" value="$(arg veh)"/>
            <arg name="param_file_name" value="$(arg param_file_name)"/>
        </include>
    </group>

    <group if="$(arg enable_anti_instagram)">
        <env name="FSM_NODE_CONTROL" value="0"/>
        <param name="/$(arg veh)/anti_instagram_node/switch" value="true"/>
        <remap from="anti_instagram_node/uncorrected_image/compressed" to="$(arg camera_topic)/image/compressed"/>
        <include file="$(find anti_instagram)/launch/anti_instagram_node.launch">
            <arg name="veh" value="$(arg veh)"/>
            <arg name="param_file_name" value="$(arg param_file_name)"/>
        </include>
    </group>

    <!-- Minimal working perception chain -->
    <remap from="~image/compressed" to="$(arg camera_topic)/image/compressed"/>
    <remap from="~camera_info" to="$(arg camera_topic)/camera_info"/>
    <group if="$(arg enable_anti_instagram)">
        <remap from="~thresholds" to="anti_instagram_node/thresholds"/>
    </group>
    <include file="$(find line_detector)/launch/line_detector_node.launch">
        <arg name="veh" value="$(arg veh)"/>
        <arg name="param_file_name" value="$(arg param_file_name)"/>
        <arg name="traffic_mode" value="$(arg traffic_mode)"/>
    </include>

    <remap from="~lineseglist_in" to="line_detector_node/segment_list"/>
    <remap from="~camera_info" to="$(arg camera_topic)/camera_info"/>
    <include file="$(find ground_projection)/launch/ground_projection_node.launch">
        <arg name="veh" value="$(arg veh)"/>
        <arg name="param_file_name" value="$(arg param_file_name)"/>
    </include>

    <!-- Optional control chain -->
    <group if="$(arg enable_lane_filter)">
        <env name="FSM_NODE_CONTROL" value="0"/>
        <param name="/$(arg veh)/lane_filter_node/switch" value="true"/>
        <remap from="lane_filter_node/segment_list" to="ground_projection_node/lineseglist_out"/>
        <remap from="lane_filter_node/left_wheel_encoder_driver_node/tick" to="left_wheel_encoder_driver_node/tick"/>
        <remap from="lane_filter_node/right_wheel_encoder_driver_node/tick" to="right_wheel_encoder_driver_node/tick"/>
        <include file="$(find lane_filter)/launch/lane_filter_node.launch">
            <arg name="veh" value="$(arg veh)"/>
            <arg name="param_file_name" value="$(arg param_file_name)"/>
        </include>
    </group>

    <group if="$(arg enable_kinematics)">
        <remap from="kinematics_node/wheels_cmd" to="wheels_driver_node/wheels_cmd"/>
        <remap from="kinematics_node/wheels_cmd_executed" to="wheels_driver_node/wheels_cmd_executed"/>
        <include file="$(find dagu_car)/launch/kinematics_node.launch">
            <arg name="veh" value="$(arg veh)"/>
            <arg name="param_file_name" value="$(arg param_file_name)"/>
        </include>
    </group>

    <group if="$(arg enable_lane_controller)">
        <remap from="lane_controller_node/lane_pose" to="lane_filter_node/lane_pose"/>
        <!-- bypass car_cmd_switch (FSM-dependent) -->
        <remap from="lane_controller_node/car_cmd" to="kinematics_node/car_cmd"/>
        <!-- feedback input for controller -->
        <remap from="lane_controller_node/wheels_cmd" to="wheels_driver_node/wheels_cmd_executed"/>
        <remap from="lane_controller_node/stop_line_reading" to="stop_line_filter_node/stop_line_reading"/>
        <remap from="lane_controller_node/obstacle_distance_reading" to="road_anomaly_watcher/obstacle_distance"/>
        <include file="$(find lane_control)/launch/lane_controller_node.launch">
            <arg name="veh" value="$(arg veh)"/>
            <arg name="param_file_name" value="$(arg param_file_name)"/>
        </include>
    </group>

</launch>
